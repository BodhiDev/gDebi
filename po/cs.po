msgid "Auto close when the install is finished"
msgstr "Automaticky zavřít po dokončení instalace"

#: ../gdebi-gtk:59
msgid "Use alternative datadir"
msgstr "Použít alternativní datový adresář"

#: ../gdebi-gtk:62
