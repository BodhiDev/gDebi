#: ../gdebi:50
#, c-format
msgid ""
"usage: %prog [options] filename\n"
"For a graphical version run gdebi-gtk\n"
msgstr "사용법: %prog [옵션] 파일 이름\n"

#: ../gdebi:56 ../gdebi-gtk:54
msgid "Run non-interactive (dangerous!)"
msgstr "대화없이 실행 (위험!)"

#: ../gdebi:60
msgid "Set an APT configuration option"
msgstr "APT 설정 옵션 설정"

