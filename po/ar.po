#: ../gdebi:50
#, c-format
msgid ""
"usage: %prog [options] filename\n"
"For a graphical version run gdebi-gtk\n"
msgstr ""
"الاستخدام:%prog [options] filename.\n"
"من أجل النسخة الرسومية نفذ gdebi-gtk.\n"

