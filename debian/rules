#!/usr/bin/make -f

PY3VER=$(shell py3versions -dvr)
DH_VERBOSE=1

export PYBUILD_TEST_ARGS={dir}/release_tests

%:
	dh $@ --with python3

override_dh_auto_clean:
	dh_auto_clean
	rm -rf build GDebi/Version.py data/gdebi.desktop po/mo

